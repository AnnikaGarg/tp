@startuml TotalCommandSequenceDiagram
skinparam defaultFontName Arial
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #555555
skinparam sequenceParticipantBackgroundColor #FEFEFE
skinparam sequenceLifeLineBorderColor #777777
skinparam shadowing false

participant ":SpendSwift" as main #LightCyan
participant "<<class>>\nParser" as parser #D5E8D4
participant ":ExpenseList" as el #DAE8FC
participant ":Ui" as ui #FFF9C4

User -> main : "total"
activate main

main -> parser : parse("total", ui)
activate parser

create participant "t:TotalCommand" as cmd #D5E8D4
parser -> cmd : new TotalCommand(ui)
activate cmd
cmd --> parser
deactivate cmd

parser --> main : t
deactivate parser

main -> cmd : execute(expenseList)
activate cmd

cmd -> el : getSize()
activate el
el --> cmd : size
deactivate el

loop size times
    cmd -> el : getExpense(i)
    activate el
    el --> cmd : expense
    deactivate el
end

cmd -> ui : showTotal(total, size)
activate ui
ui --> cmd
deactivate ui

cmd --> main
deactivate cmd
@enduml