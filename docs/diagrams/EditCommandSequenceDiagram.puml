@startuml EditCommandSequenceDiagram
hide footbox
skinparam defaultFontName Arial
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #555555
skinparam sequenceParticipantBackgroundColor #FEFEFE
skinparam sequenceLifeLineBorderColor #777777
skinparam shadowing false

participant ":SpendSwift" as main #LightCyan
participant "<<class>>\nParser" as parser #D5E8D4
participant ":ExpenseList" as el #DAE8FC
participant ":Ui" as ui #FFF9C4

User -> main : "edit 1 /a 15.0"
activate main

main -> parser : parse("edit 1 /a 15.0", ui)
activate parser

create participant "e:EditCommand" as cmd #D5E8D4
parser -> cmd : new EditCommand(ui, 1, 15.0, null, null, null)
activate cmd
cmd --> parser
deactivate cmd

parser --> main : e
deactivate parser

main -> cmd : execute(expenseList)
activate cmd

cmd -> el : getExpense(0)
activate el
el --> cmd : existingExpense
deactivate el

create participant "updated:Expense" as exp #FCE5CD
cmd -> exp : new Expense(...)
activate exp
exp --> cmd
deactivate exp

cmd -> el : setExpense(0, updated)
activate el
el --> cmd
deactivate el

cmd -> ui : showEditExpense(existingExpense, updated, 1)
activate ui
ui --> cmd
deactivate ui

cmd --> main
deactivate cmd
@enduml