@startuml
skinparam backgroundColor white
left to right direction
skinparam shadowing false

skinparam object {
    BackgroundColor #FEFEFE
    BorderColor #555555
}

object ":SpendSwift" as spendswift #D9EAD3
object ":Ui" as ui #FFF9C4
object "addCmd:AddCommand" as addCmd #D5E8D4
object "budgetCmd:BudgetCommand" as budgetCmd #D5E8D4
object ":WelcomeBanner" as banner #FCE5CD

spendswift -- ui
addCmd -- ui
budgetCmd -- ui
ui -- banner

note right of ui
Handles console input/output.

Used for:
- confirmations
- usage messages
- warnings
- interactive prompts
end note
@enduml